# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host.neon.tech/basketwise?sslmode=require

# Aldi — no API key required (HTML scraper)

# Coles — optional API key from mobile app (improves reliability)
COLES_API_KEY=your_coles_ocp_apim_subscription_key

# Woolworths — required API key from mobile app GraphQL API
WOOLWORTHS_API_KEY=your_woolworths_x_api_key

# Auth (Magic Link)
JWT_SECRET=generate-a-random-256-bit-secret-here
RESEND_API_KEY=re_your_resend_api_key_here
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Stripe Premium Subscription
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PRICE_ID=price_your_stripe_price_id
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
