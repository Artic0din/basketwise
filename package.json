{
  "name": "basketwise",
  "version": "0.0.0",
  "description": "Australian grocery price comparison web app",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "scrape:coles": "tsx src/scrapers/scrape.ts --store coles",
    "scrape:woolworths": "tsx src/scrapers/scrape.ts --store woolworths",
    "scrape:aldi": "tsx src/scrapers/scrape.ts --store aldi",
    "scrape:all": "tsx src/scrapers/scrape.ts",
    "health": "tsx src/health/check.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@stripe/stripe-js": "^9.2.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.2",
    "lucide-react": "^1.8.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "resend": "^6.12.0",
    "stripe": "^22.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
